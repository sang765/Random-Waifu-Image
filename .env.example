# Discord Webhooks
# Get these from your Discord channel settings -> Integrations -> Webhooks
SFW_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_SFW_WEBHOOK_ID/YOUR_SFW_WEBHOOK_TOKEN
NSFW_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_NSFW_WEBHOOK_ID/YOUR_NSFW_WEBHOOK_TOKEN

# Image Source Configuration
# Options: waifu.im, nekosapi, waifu.pics, pic.re, nekos.best, danbooru, rule34, tbib, both, random
# - waifu.im: Use waifu.im API only (default)
# - nekosapi: Use NekosAPI (nekosapi.com) only
# - waifu.pics: Use waifu.pics API only
# - pic.re: Use Pic.re API only (SFW only, 66,930+ artworks)
# - nekos.best: Use nekos.best API only (SFW GIFs and images)
# - danbooru: Use Danbooru API (requires credentials below)
# - rule34: Use Rule 34 API (requires credentials below)
# - tbib: Use TBIB (The Big ImageBoard) API (no credentials required)
# - both: Randomly select from all sources
# - random: Alias for 'both', randomly select from all sources
IMAGE_SOURCE=random

# Danbooru API Configuration (Optional - only needed if IMAGE_SOURCE=danbooru)
# Get your API key from: https://danbooru.donmai.us/profile
# Click "Generate API key" and copy your username and API key
DANBOORU_USERNAME=your_danbooru_username
DANBOORU_API_KEY=your_danbooru_api_key

# Rule 34 API Configuration (Optional - only needed if IMAGE_SOURCE=rule34)
# Get your API key from: https://rule34.xxx/index.php?page=account&s=options
# Copy your user ID and API key
RULE34_USER_ID=your_rule34_user_id
RULE34_API_KEY=your_rule34_api_key

# Rule 34 AI Content Filter (Optional)
# Set to true to disable posting AI-generated images from Rule 34
# Default: true (AI images will be filtered out)
R34_DISABLE_AI_POST=true

# TBIB (The Big ImageBoard) Configuration (Optional)
# TBIB is a Danbooru-like image board with JSON API support
# No authentication required - just set IMAGE_SOURCE=tbib to use it
# TBIB AI Content Filter (Optional)
# Set to true to disable posting AI-generated images from TBIB
# Default: true (AI images will be filtered out)
TBIB_DISABLE_AI_POST=false

# Posting Configuration
# Comma-separated list of tags to include (e.g., "waifu,maid"). Leave empty for random.
# Note: Tags differ between sources. See README for available tags.
DEFAULT_TAGS=

# Cron schedule for automatic posting (default: every 6 hours)
# Format: minute hour day month day-of-week
# Examples: "0 */6 * * *" = every 6 hours, "0 0 * * *" = daily at midnight
CRON_SCHEDULE=0 */6 * * *

# What to post (set to false to disable)
POST_SFW=true
POST_NSFW=false

# Number of images to fetch per request (1-30)
FETCH_LIMIT=1
